{
  "kind": "collectionType",
  "collectionName": "promotions",
  "info": {
    "singularName": "promotion",
    "pluralName": "promotions",
    "displayName": "Promotion"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "mappedBy": "promotions"
    },
    "title": {
      "type": "string"
    },
    "slug": {
      "type": "uid"
    },
    "banner": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "short_description": {
      "type": "text"
    },
    "content": {
      "type": "blocks"
    },
    "start_date": {
      "type": "datetime"
    },
    "end_date": {
      "type": "datetime"
    },
    "cta_label": {
      "type": "string"
    },
    "cta_link": {
      "type": "string"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": true
    }
  }
}
