{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "slug": {
      "type": "uid"
    },
    "template": {
      "type": "enumeration",
      "enum": [
        "default",
        "home",
        "personal",
        "landing"
      ]
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "blocks.rich-text",
        "blocks.product-highlight",
        "blocks.news-block",
        "blocks.feature-grid",
        "blocks.faq-block",
        "blocks.cta-banner",
        "shared.slider",
        "blocks.banners-main"
      ]
    },
    "workflowState": {
      "type": "enumeration",
      "enum": [
        "draft",
        "published"
      ]
    },
    "publishDate": {
      "type": "datetime"
    }
  }
}
